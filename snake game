WARNING_HIDE_1 = 0.20
WARNING_SHOW_2 = 0.35
WARNING_HIDE_2 = 0.20
WARNING_SHOW_3 = 0.35

DANGER_TOTAL_DURATION = 1.25
DANGER_SWAP_INTERVAL = 0.15
TRAP_RESPAWN_DELAY = 10.0
FIRST_TRAP_DELAY = 3.0

